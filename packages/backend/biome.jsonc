{
	"$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/*.{ts,tsx,js,cjs,jsonc}",
			"!**/node_modules",
			"!built",
			"!built-test"
		]
	},
	"overrides": [
		{
			"includes": [
				"migration/**/*",
				"test/**/*",
				"test-federation/test/**/*",
				"test-server/**/*"
			],
			"linter": {
				"rules": {
					"correctness": {
						// in migration, we often have catch without using the error
						"noUnusedFunctionParameters": "off",
						"noUnusedVariables": "off"
					}
				}
			}
		},
		{
			"includes": [
				"assets/**/*.js"
			],
			"javascript": {
				"globals": [
					"document"
				]
			}
		}
	],
	"formatter": {
		"enabled": false,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noImportantStyles": {
					"level": "off"
				},
				// for services, we declare constructors without parameters
				"noUselessConstructor": {
					"level": "off"
				},
				"useLiteralKeys": {
					"level": "off"
				},
				"noStaticOnlyClass": {
					"level": "off"
				}
			},
			"correctness": {
				"noUnusedFunctionParameters": {
					"level": "off"
				},
				"useParseIntRadix": {
					"level": "off"
				},
				"noUnusedVariables": {
					"level": "warn",
					"options": {
						// https://github.com/biomejs/biome/issues/8353
						// https://github.com/biomejs/biome/pull/8398
						"ignoreRestSiblings": true
					}
				}
			},
			"style": {
				"useTemplate": {
					"fix": "safe"
				},
				"noNonNullAssertion": {
					"level": "off"
				},
				"noParameterProperties": {
					"level": "off"
				},
				"useImportType": {
					"level": "error",
					"options": {
						"style": "separatedType"
					}
				}
			},
			"suspicious": {
				"noExplicitAny": {
					"level": "off"
				},
				// false positive in script tag
				// https://github.com/biomejs/biome/issues/8431
				"noSuspiciousSemicolonInJsx": {
					"level": "off"
				},
				"noShadowRestrictedNames": {
					"level": "off"
				},
				"noControlCharactersInRegex": {
					"level": "off"
				},
				"noThenProperty": {
					"level": "off"
				}
			},
			"a11y": {
				"useHtmlLang": {
					"level": "off"
				},
				"useAltText": {
					"level": "off"
				},
				"noSvgWithoutTitle": {
					"level": "off"
				},
				"useButtonType": {
					"level": "off"
				}
			}
		}
	},
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		},
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
